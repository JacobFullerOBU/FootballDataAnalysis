# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DATABASE_PATH=./data/football.db

# External API Keys (for future integration)
# ESPN_API_KEY=your_espn_api_key_here
# ODDS_API_KEY=your_odds_api_key_here
# SPORTS_RADAR_API_KEY=your_sports_radar_api_key_here

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Data Fetching Configuration
DATA_FETCH_INTERVAL=daily
DATA_FETCH_TIME=06:00